{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "promise", "node", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "no-underscore-dangle": "off",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/.wrangler/**",
    "**/node_modules/**",
    "**/.vitest/**",
    "**/coverage/**"
  ]
}
