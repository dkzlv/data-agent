{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "data-agent-web",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "2f7029a7ef2671db090d9304f595c42d",

  "observability": {
    "enabled": true
  },

  "vars": {
    // Until DNS is wired (custom domain + cookie scope), point at the
    // workers.dev deployment so the alpha is testable end-to-end.
    "API_URL": "https://data-agent-api-gateway.dkzlv.workers.dev",
    "APP_URL": "https://data-agent-web.dkzlv.workers.dev"
  }

  // Routes wired at first deploy:
  //   "routes": [{ "pattern": "app.data-agent.dkzlv.com/*", "custom_domain": true }]
}
