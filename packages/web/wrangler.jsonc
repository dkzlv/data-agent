{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "data-agent-web",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "2f7029a7ef2671db090d9304f595c42d",

  "observability": {
    "enabled": true
  },

  "vars": {
    // Web at the apex, api-gateway at `api.` of the same registrable
    // domain so the auth cookie is first-party to both (Lax + Domain
    // =.data-agent.dkzlv.com). Earlier alpha had api on *.workers.dev
    // which broke sign-in once web moved off workers.dev — browsers
    // refused to send the cross-site cookie.
    "API_URL": "https://api.data-agent.dkzlv.com",
    "APP_URL": "https://data-agent.dkzlv.com"
  },

  // First deploy needs `wrangler deploy --override-existing-dns-record`
  // because the apex record was pre-created in the dashboard
  // (CF API code 100117 otherwise). Subsequent deploys don't.
  "routes": [{ "pattern": "data-agent.dkzlv.com", "custom_domain": true }]
}
