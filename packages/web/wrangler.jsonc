{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "data-agent-web",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "2f7029a7ef2671db090d9304f595c42d",

  "observability": {
    "enabled": true
  },

  "vars": {
    // Single-origin: api-gateway is mounted as a Route at `/api/*`
    // on the same hostname (see api-gateway/wrangler.jsonc routes).
    // `API_URL` is the SAME as `APP_URL` so the browser uses
    // relative-equivalent same-origin requests — no CORS, no
    // preflights, and the auth cookie is host-only + SameSite=Lax.
    // Earlier alpha had api on `api.data-agent.dkzlv.com`, which
    // Brave Shields treated as cross-site and broke sign-in across
    // tabs (intermittent ERR_BLOCKED_BY_RESPONSE 403). See decision
    // #10 in AGENTS.md.
    "API_URL": "https://data-agent.dkzlv.com",
    "APP_URL": "https://data-agent.dkzlv.com"
  },

  // First deploy needs `wrangler deploy --override-existing-dns-record`
  // because the apex record was pre-created in the dashboard
  // (CF API code 100117 otherwise). Subsequent deploys don't.
  "routes": [{ "pattern": "data-agent.dkzlv.com", "custom_domain": true }]
}
