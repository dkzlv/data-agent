{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "data-agent-api-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "2f7029a7ef2671db090d9304f595c42d",

  "observability": {
    "enabled": true
  },

  // Match chat-agent's CPU bump (5 min). The api-gateway is the
  // entry point for the WebSocket upgrade, so its request lifetime
  // spans the full chat session — same CPU-cap exposure as the DO.
  "limits": {
    "cpu_ms": 300000
  },

  "vars": {
    // workers.dev URLs until custom domains are provisioned. Cookies on
    // workers.dev can't be cross-subdomain, so the alpha is single-host:
    // we'll need either a CNAME setup or to host the api-gateway behind
    // app.data-agent.dkzlv.com via a sub-path before public launch.
    "APP_URL": "https://data-agent-web.dkzlv.workers.dev",
    "API_URL": "https://data-agent-api-gateway.dkzlv.workers.dev",
    "COOKIE_DOMAIN": "data-agent-api-gateway.dkzlv.workers.dev",
    "CF_ACCOUNT_ID": "2f7029a7ef2671db090d9304f595c42d",
    // Closed-alpha allow-list for magic-link signups. Comma-separated
    // domain suffixes (no `@`). Set to `*` to disable the gate.
    // Mismatched addresses get a silent no-op so attackers can't
    // enumerate which domains are permitted.
    "ALLOWED_EMAIL_DOMAINS": "indent.com"
  },

  "secrets_store_secrets": [
    {
      "binding": "CONTROL_PLANE_DB_URL",
      "store_id": "5fca98fdba4f4972b9d14ac74ea58cf4",
      "secret_name": "CONTROL_PLANE_DB_URL"
    },
    {
      "binding": "BETTER_AUTH_SECRET",
      "store_id": "5fca98fdba4f4972b9d14ac74ea58cf4",
      "secret_name": "BETTER_AUTH_SECRET"
    },
    {
      "binding": "INTERNAL_JWT_SIGNING_KEY",
      "store_id": "5fca98fdba4f4972b9d14ac74ea58cf4",
      "secret_name": "INTERNAL_JWT_SIGNING_KEY"
    },
    {
      "binding": "MASTER_ENCRYPTION_KEY",
      "store_id": "5fca98fdba4f4972b9d14ac74ea58cf4",
      "secret_name": "MASTER_ENCRYPTION_KEY"
    }
  ],

  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "data-agent-artifacts"
    }
  ],

  "services": [
    {
      "binding": "CHAT_AGENT",
      "service": "data-agent-chat-agent"
    }
  ],

  // Cloudflare Email Sending binding (open beta product, distinct
  // from Email Routing's send_email). Sender domain `dkzlv.com` is
  // already onboarded — `wrangler email sending list` confirms
  // `enabled: yes`. `remote: true` is required for the binding to
  // hit the live Email Sending product (without it, the binding
  // talks to the older Email Routing send pathway, which only
  // delivers to verified destinations).
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true,
      "allowed_sender_addresses": ["robot@data-agent.dkzlv.com"]
    }
  ]

  // Routes wired at deploy time:
  //   "routes": [{ "pattern": "api.data-agent.dkzlv.com/*", "custom_domain": true }]
  // — left out of jsonc until first deploy so dev keeps using *.workers.dev
}
